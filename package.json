{
  "private": true,
  "scripts": {
    "start": "concurrently --raw npm:docs:shell npm:docs:components",
    "docs:components": "cd docs/latest; npm run start",
    "docs:shell": "cd docs/shell; npm run start",
    "docs:build:shell": "cd docs/shell; npm run build",
    "docs:build:components": "cd docs/latest; npm run build",
    "lint": "eslint . '*/**/*.{js,ts,tsx,mts}' && tsc --noEmit -p components/ && tsc --noEmit -p assets/ && tsc --noEmit -p tests/ && tsc --noEmit -p docs/common && tsc --noEmit -p docs/latest && tsc --noEmit -p docs/shell && stylelint 'components/**/*.html' 'components/**/*.css' 'assets/**/*.html' 'assets/**/*.css' 'docs/**/*.css'",
    "test": "pnpm --dir tests test"
  },
  "devDependencies": {
    "@sinch-engage/nectary": "workspace:*",
    "@types/node": "^18.11.18",
    "@types/svgo": "^2.6.4",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "concurrently": "^7.6.0",
    "emojibase": "^6.1.0",
    "emojibase-data": "^7.0.1",
    "eslint": "^8.33.0",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-mdx": "^2.0.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react": "^7.32.2",
    "postcss-html": "^1.5.0",
    "rimraf": "^4.1.2",
    "slackify-markdown": "^4.3.1",
    "stylelint": "^14.16.1",
    "stylelint-config-standard": "^25.0.0",
    "svgo": "^2.8.0",
    "tsm": "^2.3.0",
    "typescript": "^4.9.5"
  }
}
