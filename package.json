{
  "private": true,
  "name": "nectary",
  "scripts": {
    "dry-run": "multi-semantic-release --sequential-init --ignore-private-packages --dry-run",
    "release": "multi-semantic-release --sequential-init --ignore-private-packages",
    "commit": "commit",
    "commitlint": "commitlint -e",
    "prepare": "is-ci || husky install",
    "start": "concurrently --raw npm:docs:shell npm:docs:components",
    "docs:components": "cd docs/latest; npm run start",
    "docs:shell": "cd docs/shell; npm run start",
    "docs:build:shell": "cd docs/shell; npm run build",
    "docs:build:components": "cd docs/latest; npm run build",
    "lint": "eslint . '*/**/*.{ts,tsx,mts}' && tsc --noEmit -p components/ && tsc --noEmit -p assets/ && tsc --noEmit -p tests/ && tsc --noEmit -p docs/common && tsc --noEmit -p docs/latest && tsc --noEmit -p docs/shell && stylelint 'components/**/*.html' 'components/**/*.css' 'assets/**/*.html' 'assets/**/*.css' 'docs/**/*.css'",
    "test": "pnpm --dir tests test",
    "tokens:base": "tsm ./scripts/process-tokens.ts ./tokens/data.json themes/base base",
    "tokens:dark": "tsm ./scripts/process-tokens.ts ./tokens/data.json themes/dark dark",
    "tokens:mm": "tsm ./scripts/process-tokens.ts ./tokens/data.json themes/message-media messagemedia",
    "tokens:simpletexting": "tsm ./scripts/process-tokens.ts ./tokens/data.json themes/simple-texting simpletexting",
    "tokens:cpass:base": "tsm ./scripts/process-tokens.ts ./tokens/data.json themes/cpaas-base cpaas/base",
    "tokens:cpass:mailgun": "tsm ./scripts/process-tokens.ts ./tokens/data.json themes/cpaas-mailGun cpaas/mailgun",
    "tokens:cpass:mailjet": "tsm ./scripts/process-tokens.ts ./tokens/data.json themes/cpaas-mailJet cpaas/mailjet",
    "tokens:cpass:dashboard": "tsm ./scripts/process-tokens.ts ./tokens/data.json themes/cpaas-dashboard cpaas/dashboard",
    "tokens": "concurrently --raw npm:tokens:base npm:tokens:dark npm:tokens:mm npm:tokens:cpass:base npm:tokens:cpass:mailgun npm:tokens:cpass:mailjet npm:tokens:cpass:dashboard npm:tokens:simpletexting",
    "wrappers:react": "tsm ./scripts/generate-react-wrappers.mts",
    "wrappers:slots": "tsm ./scripts/generate-slots-for-wrappers.mts",
    "wrappers:types": "tsm ./scripts/generate-types-for-wrappers.mts",
    "wrappers": "pnpm wrappers:types && concurrently --raw npm:wrappers:react npm:wrappers:slots && eslint ./wrappers/**/src/**/* --fix"
  },
  "devDependencies": {
    "@alex-e-leon/stylelint-value-no-unknown-custom-properties": "^4.0.2",
    "@nectary/components": "workspace:*",
    "@nectary/eslint-plugin": "workspace:*",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^18.17.17",
    "@types/svgo": "^2.6.4",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "concurrently": "^7.6.0",
    "csv-parse": "^5.5.0",
    "emojibase": "^6.1.0",
    "emojibase-data": "^7.0.1",
    "eslint": "^8.49.0",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-mdx": "^2.2.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react": "^7.33.2",
    "husky": "^9.0.11",
    "is-ci": "^3.0.1",
    "multi-semantic-release": "^3.0.2",
    "postcss-html": "^1.5.0",
    "rimraf": "^4.4.1",
    "slackify-markdown": "^4.4.0",
    "stylelint": "^14.16.1",
    "stylelint-config-standard": "^25.0.0",
    "svgo": "^2.8.0",
    "tsm": "^2.3.0",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "jsdom": "^24.0.0",
    "labs": "^2.0.2"
  },
  "release": {
    "branches": [
      "main"
    ],
    "tagFormat": "sr-v${version}",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
