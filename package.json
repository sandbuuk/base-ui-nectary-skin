{
  "private": true,
  "workspaces": [
    "components/",
    "configs/*",
    "libs/*",
    "tests/visual",
    "tests/visual/apps/*",
    "tests/accessibility"
  ],
  "scripts": {
    "storybook": "start-storybook --port 4000",
    "storybook:build": "build-storybook --output-dir public --quiet",
