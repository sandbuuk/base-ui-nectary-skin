{
  "private": true,
  "scripts": {
    "start": "cd docs; npm start",
    "docs:build": "cd docs; npm run build",
    "storybook": "start-storybook --port 4000",
    "storybook:build": "build-storybook --output-dir public/storybook --quiet",
    "lint": "eslint . '*/**/*.{js,ts,tsx,mts}' && tsc --noEmit -p components/ && tsc --noEmit -p tests/ && tsc --noEmit -p docs/ && tsc --noEmit -p stories/ && stylelint 'components/**/*.html' 'components/**/*.css' 'docs/**/*.css'",
    "test": "yarn --cwd=tests test"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@sinch-engage/nectary": "workspace:*",
