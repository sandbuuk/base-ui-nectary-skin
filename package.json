{
  "private": true,
  "workspaces": [
    "components/",
    "configs/*",
    "libs/*"
  ],
  "scripts": {
    "storybook": "start-storybook --port 4000",
    "build-storybook": "build-storybook --output-dir public",
    "lint": "eslint . '*/**/*.{js,ts,tsx}' && tsc --noEmit --declaration false && stylelint 'components/**/*.html'",
    "test": "concurrently --success=first --kill-others --raw npm:test-playwright npm:test-storybook",
    "test-playwright": "wait-on http://localhost:4000 && PLAYWRIGHT_BROWSERS_PATH=.browsers/ playwright test --browser=all",
    "test-playwright-install": "PLAYWRIGHT_BROWSERS_PATH=.browsers/ playwright install",
    "test-storybook": "BROWSER=none start-storybook --port 4000 --ci --quiet"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@babel/preset-env": "^7.16.0",
    "@playwright/test": "^1.16.3",
    "@saas/components": "*",
    "@storybook/addon-essentials": "^6.3.12",
    "@storybook/addons": "^6.3.12",
    "@storybook/client-api": "^6.3.12",
    "@storybook/html": "^6.3.12",
    "@types/node": "^14.0.0",
    "babel-loader": "^8.2.3",
    "concurrently": "^6.3.0",
    "eslint": "^7.0.0",
    "postcss-html": "^1.2.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "stylelint": "^14.0.0",
    "stylelint-config-standard": "^23.0.0",
    "typescript": "^4.4.2",
    "wait-on": "^6.0.0",
    "webpack": "^5.63.0"
  }
}
