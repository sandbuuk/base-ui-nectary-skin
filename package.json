{
  "private": true,
  "workspaces": [
    "apps/*",
    "components/"
  ],
  "scripts": {
    "start": "concurrently --raw npm:react-1 npm:react-2 npm:vue npm:angular npm:shell",
    "react-1": "webpack serve --config apps/react-1/webpack.config.js",
    "react-2": "webpack serve --config apps/react-2/webpack.config.js",
    "vue": "webpack serve --config apps/vue/webpack.config.js",
    "angular": "yarn workspace angular-app start",
    "shell": "wait-on http://localhost:3001/ http://localhost:3002/ http://localhost:3003/ http://localhost:3004/ && webpack serve --config apps/shell/webpack.config.js",
    "storybook": "start-storybook --port 4000",
    "build-storybook": "build-storybook"
  },
  "devDependencies": {
    "@babel/core": "^7.15.5",
    "@babel/preset-env": "^7.15.4",
    "@babel/preset-typescript": "^7.15.0",
    "@module-federation/fmr": "^0.0.7",
    "@storybook/addon-actions": "^6.3.8",
    "@storybook/addon-essentials": "^6.3.8",
    "@storybook/addon-links": "^6.3.8",
    "@storybook/client-api": "^6.3.8",
    "@storybook/html": "^6.3.8",
    "@types/node": "^14.0.0",
    "babel-loader": "^8.2.2",
    "concurrently": "^6.2.1",
    "css-loader": "^6.2.0",
    "html-webpack-plugin": "^5.3.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "style-loader": "^3.2.1",
    "typescript": "^4.4.2",
    "wait-on": "^6.0.0",
    "webpack-cli": "^4.8.0",
    "webpack-dev-server": "^4.1.0",
    "webpack": "^5.52.0"
  }
}
