{
  "private": true,
  "workspaces": [
    "components/",
    "configs/*",
    "libs/*",
    "apps/*",
    "tests/visual",
    "tests/visual/apps/*",
    "tests/accessibility"
  ],
  "scripts": {
    "storybook": "start-storybook --port 4000",
    "storybook:build": "build-storybook --output-dir public --quiet",
    "lint": "eslint . '*/**/*.{js,ts,tsx}' && tsc --noEmit --declaration false && stylelint 'components/**/*.html' 'components/theme.css'",
    "start:quickstarts": "webpack serve --config apps/quickstarts/webpack.dev.js",
    "start:shell": "wait-on http://localhost:3001 && REMOTE_QUICKSTARTS=localhost:3001 webpack serve --config apps/shell/webpack.dev.js",
    "start": "concurrently --raw npm:start:quickstarts npm:start:shell",
    "build:quickstarts": "webpack build --config apps/quickstarts/webpack.prod.js --output-path apps/quickstarts/dist",
    "build:shell": "webpack build --config apps/shell/webpack.prod.js --output-path apps/shell/dist",
    "test:visual": "yarn --cwd=tests/visual test",
    "test:accessibility": "yarn --cwd=tests/accessibility test",
    "test": "concurrently --raw npm:test:visual npm:test:accessibility"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@babel/preset-env": "^7.16.0",
    "@nectary/components": "*",
    "@storybook/addon-essentials": "^6.3.12",
    "@storybook/addons": "^6.3.12",
    "@storybook/client-api": "^6.3.12",
    "@storybook/html": "^6.3.12",
    "@types/node": "^14.0.0",
    "babel-loader": "^8.2.3",
    "css-loader": "^6.5.1",
    "eslint": "^7.0.0",
    "html-webpack-plugin": "^5.5.0",
    "postcss-html": "^1.2.0",
    "raw-loader": "^4.0.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "slackify-markdown": "^4.3.0",
    "style-loader": "^3.3.1",
    "stylelint": "^14.0.0",
    "stylelint-config-standard": "^23.0.0",
    "typescript": "^4.4.2",
    "webpack": "^5.64.0",
    "webpack-cli": "^4.9.1",
    "webpack-dev-server": "^4.5.0"
  }
}
