{
  "private": true,
  "scripts": {
    "start": "cd docs; npm start",
    "docs:build": "cd docs; npm run build",
    "storybook": "start-storybook --port 4000",
    "storybook:build": "build-storybook --output-dir public/storybook --quiet",
    "lint": "eslint . '*/**/*.{js,ts,tsx,mts}' && tsc --noEmit -p components/ && tsc --noEmit -p tests/ && tsc --noEmit -p docs/ && tsc --noEmit -p stories/ && stylelint 'components/**/*.html' 'components/theme.css' 'docs/**/*.css'",
    "test": "yarn --cwd=tests test"
  },
  "devDependencies": {
    "@babel/core": "^7.17.0",
    "@babel/preset-env": "^7.16.11",
    "@sinch-engage/nectary": "workspace:@sinch-engage/nectary@*",
    "@storybook/addon-essentials": "^6.5.9",
    "@storybook/addons": "^6.5.9",
    "@storybook/client-api": "^6.5.9",
    "@storybook/html": "^6.5.9",
    "@types/node": "^17.0.14",
    "@types/svgo": "^2.6.3",
    "@typescript-eslint/eslint-plugin": "^5.16.0",
    "@typescript-eslint/parser": "^5.16.0",
    "babel-loader": "^8.2.3",
    "css-loader": "^6.5.1",
    "eslint": "^8.13.0",
    "eslint-import-resolver-typescript": "^2.7.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-mdx": "^2.0.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-react": "^7.29.4",
    "html-webpack-plugin": "^5.5.0",
    "postcss-html": "^1.2.0",
    "raw-loader": "^4.0.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "slackify-markdown": "^4.3.0",
    "style-loader": "^3.3.1",
    "stylelint": "^14.0.0",
    "stylelint-config-standard": "^25.0.0",
    "svgo": "^2.8.0",
    "tsm": "^2.2.1",
    "typescript": "^4.4.2",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.9.1",
    "webpack-dev-server": "^4.10.1"
  }
