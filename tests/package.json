{
  "name": "visual-tests",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test:ci": "npm run test:app-all && npm run test:playwright",
    "test:playwright": "wait-on http://localhost:3021 && wait-on http://localhost:3022 && wait-on http://localhost:3023 && playwright test",
    "test:bash": "wait-on http://localhost:3021 && wait-on http://localhost:3022 && wait-on http://localhost:3023 && /bin/bash",
    "test:app-all": "concurrently --raw npm:test:app-react npm:test:app-vue npm:test:app-angular",
    "test:app-react": "webpack serve --config apps/react/webpack.config.js &",
    "test:app-vue": "webpack serve --config apps/vue/webpack.config.js &",
    "test:app-angular": "cd ./apps/angular; ng serve &",
    "test:dev": "docker run -it --rm --ipc=host --network host -v $PWD/..:/app:delegated -v $PWD/../fonts:/root/.fonts --workdir=/app mcr.microsoft.com/playwright:v1.20.1 ./tests/entrypoint.dev.sh",
    "test": "docker run -it --rm --ipc=host -v $PWD/..:/app:delegated -v $PWD/../fonts:/root/.fonts --workdir=/app mcr.microsoft.com/playwright:v1.20.1 ./tests/entrypoint.sh",
    "remove-empty-dirs": "find ./test-results -type d -empty -delete"
  },
  "devDependencies": {
    "@babel/core": "^7.17.0",
    "@babel/preset-env": "^7.16.0",
    "@playwright/test": "1.20.1",
    "@sinch-engage/nectary": "*",
    "@types/node": "^17.0.14",
    "babel-loader": "^8.2.3",
    "concurrently": "^7.1.0",
    "css-loader": "^6.5.1",
    "html-webpack-plugin": "^5.5.0",
    "postcss-html": "^1.2.0",
    "raw-loader": "^4.0.2",
    "style-loader": "^3.3.1",
    "wait-on": "^6.0.0",
    "webpack": "^5.64.2",
    "webpack-cli": "^4.9.1",
    "webpack-dev-server": "^4.5.0"
  }
}
