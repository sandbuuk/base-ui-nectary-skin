/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": ["node"],
    "paths": {
      "@nectary/shared": ["../../../shared/index.ts"],
      "@nectary/components/*": ["../../../components/*"],
      "@nectary/assets/*": ["../../../assets/*"],
      "@nectary/theme-base/*": ["../../../themes/base/*"],
      "tslib": ["node_modules/tslib"]
    }
  },
  "files": [
    "src/main.ts",
    "src/polyfills.ts",
    "imports.d.ts"
  ],
  "include": [
    "src/**/*.d.ts"
  ]
}
