{
  "name": "accessibility-tests",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "test:ci": "concurrently --success=first --kill-others --raw npm:test:playwright npm:test:app",
    "test:playwright": "wait-on http://localhost:3011 && playwright test",
    "test:app": "webpack serve --config webpack.config.js",
    "test:dev": "docker run -it --rm --ipc=host --network host -v $PWD/../..:/app:delegated -v $PWD/../../fonts:/root/.fonts --workdir=/app mcr.microsoft.com/playwright:v1.17.1 ./tests/accessibility/entrypoint.dev.sh",
    "test": "docker run -it --rm --ipc=host --network host -v $PWD/../..:/app:delegated -v $PWD/../../fonts:/root/.fonts --workdir=/app mcr.microsoft.com/playwright:v1.17.1 ./tests/accessibility/entrypoint.sh"
  },
  "devDependencies": {
    "@babel/core": "^7.17.0",
    "@babel/preset-env": "^7.16.0",
    "@babel/preset-typescript": "^7.16.0",
    "@sinch-engage/nectary": "*",
    "@playwright/test": "1.17.1",
    "@types/node": "^17.0.14",
    "axe-core": "^4.3.5",
    "babel-loader": "^8.2.3",
    "concurrently": "^6.3.0",
    "css-loader": "^6.5.1",
    "html-webpack-plugin": "^5.5.0",
    "raw-loader": "^4.0.2",
    "style-loader": "^3.3.1",
    "wait-on": "^6.0.0",
    "webpack": "^5.64.2",
    "webpack-cli": "^4.9.1",
    "webpack-dev-server": "^4.5.0"
  }
}
