{
  "compilerOptions": {
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "pretty": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "exactOptionalPropertyTypes": true,
    "strictNullChecks": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true
  }
}