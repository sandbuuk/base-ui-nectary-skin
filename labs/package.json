{
  "name": "@nectary/labs",
  "version": "2.8.3",
  "files": [
    "**/*/*.css",
    "**/*/*.json",
    "**/*/*.js",
    "**/*/*.d.ts",
    "*.d.ts",
    "*.js",
    "*.html",
    "**/*/*.html"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && npx tsc --declaration --emitDeclarationOnly",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@nectary/components": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.12.0",
    "@types/react": "^18.2.21",
    "glob": "^11.0.1",
    "typescript": "^5.2.2",
    "vite": "^7.0.6"
  }
}
