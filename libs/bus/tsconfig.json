{
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "pretty": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "jsx": "preserve",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "declaration": true,
    "noEmit": false,
    "emitDeclarationOnly": true
  }
}
