{
  "compilerOptions": {
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "pretty": true,
    "lib": [
      "esnext",
      "dom",
    ],
    "jsx": "react-jsx",
    "target": "esnext",
    "module": "nodenext",
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
  }
}