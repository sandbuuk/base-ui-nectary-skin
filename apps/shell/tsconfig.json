{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "pretty": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "jsx": "preserve",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "paths": {
      "Quickstarts/Container": [
        "./types.d.ts"
      ]
    }
  },
}
