{
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "pretty": true,
    "lib": ["esnext", "dom"],
    "jsx": "react-jsx",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "noImplicitAny": false,
    "typeRoots": [
      "../node_modules/@types",
      "../@types"
    ]
  },
  "include": ["./src", "./modules.d.ts", "./custom.d.ts"],
}
