{
  "name": "@nectary/components",
  "version": "2.8.8",
  "files": [
    "lib"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./changelog.md": "./changelog.md",
    "./*/types": "./lib/esm/*/types.d.ts",
    "./*.json": "./lib/esm/*.json",
    "./utils/*.json": "./lib/esm/utils/*.json",
    "./*/utils": {
      "types": "./lib/esm/*/utils.d.ts",
      "require": "./lib/cjs/*/utils.js",
      "default": "./lib/esm/*/utils.js"
    },
    "./utils/*": {
      "types": "./lib/esm/utils/*.d.ts",
      "require": "./lib/cjs/utils/*.js",
      "default": "./lib/esm/utils/*.js"
    },
    "./utils": {
      "types": "./lib/esm/utils/index.d.ts",
      "require": "./lib/cjs/utils/index.js",
      "default": "./lib/esm/utils/index.js"
    },
    "./*": {
      "types": "./lib/esm/*/index.d.ts",
      "require": "./lib/cjs/*/index.js",
      "default": "./lib/esm/*/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "rimraf lib",
    "build": "./build-lib.sh"
  },
  "dependencies": {
    "@babel/runtime": "^7.22.15"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.15",
    "@babel/core": "^7.22.20",
    "@babel/plugin-transform-modules-commonjs": "^7.24.1",
    "@babel/plugin-transform-runtime": "^7.22.15",
    "@babel/preset-env": "^7.22.20",
    "@babel/preset-typescript": "^7.22.15",
    "@types/node": "^18.17.17",
    "@types/react": "^18.2.21",
    "babel-plugin-html-inline-minifier": "workspace:*",
    "rimraf": "^5.0.7",
    "typescript": "^5.2.2"
  }
}
