    "@babel/preset-env": "^7.20.2",
    "@babel/preset-typescript": "^7.18.6",
    "@types/node": "^18.11.18",
    "@types/react": "^18.0.27",
    "babel-plugin-html-inline-minifier": "workspace:^0.0.0",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "typescript": "^4.9.5"
