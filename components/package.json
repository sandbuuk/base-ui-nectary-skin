{
  "name": "@saas/components",
  "version": "0.0.0",
  "files": [
    "theme.css",
    "**/*/*.js",
    "**/*/*.d.ts",
    "utils.js",
    "utils.d.ts"
  ],
  "scripts": {
    "prebuild": "rimraf utils.{js,d.ts} */*.{js,d.ts} */**/*.{js,d.ts}",
    "build": "babel . --extensions '.ts' --ignore '*.d.ts' --out-dir .",
    "postbuild": "tsc"
  },
  "dependencies": {
    "@babel/runtime": "^7.16.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.16.0",
    "@babel/core": "^7.16.0",
    "@babel/plugin-transform-runtime": "^7.16.0",
    "@babel/preset-env": "^7.16.0",
    "@babel/preset-typescript": "^7.16.0",
    "rimraf": "^3.0.2",
    "typescript": "^4.4.2"
  }
}
