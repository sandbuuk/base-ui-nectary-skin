{
  "name": "@nectary/components",
  "version": "2.8.8",
  "files": [
    "lib"
  ],
  "exports": {
    "./*": {
      "types": "./lib/esm/*/index.d.ts",
      "import": "./lib/esm/*.js",
      "require": "./lib/cjs/*.js",
      "default": "./lib/esm/*.js"
    },
    "./*.json": {
      "types": "./lib/esm/*.json",
      "import": "./lib/esm/*.json",
      "require": "./lib/cjs/*.json",
      "default": "./lib/esm/*.json"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "rimraf lib",
    "build": "./build-lib.sh"
  },
  "dependencies": {
    "@babel/runtime": "^7.22.15"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.15",
    "@babel/core": "^7.22.20",
    "@babel/plugin-transform-modules-commonjs": "^7.24.1",
    "@babel/plugin-transform-runtime": "^7.22.15",
    "@babel/preset-env": "^7.22.20",
    "@babel/preset-typescript": "^7.22.15",
    "@types/node": "^18.17.17",
    "@types/react": "^18.2.21",
    "babel-plugin-html-inline-minifier": "workspace:*",
    "rimraf": "^5.0.7",
    "typescript": "^5.2.2"
  }
}
