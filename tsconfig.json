{
  "compilerOptions": {
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "pretty": true,
    "noEmit": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "jsx": "react-jsx",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
      "paths": {
        "@nectary/shared": ["./shared/index.ts"]
      }
  }
}
