{
  "name": "@nectary/assets",
  "version": "3.0.0",
  "files": [
    "**/*/*.css",
    "**/*/*.json",
    "**/*/*.js",
    "**/*/*.d.ts",
    "bundle.ts",
    "bundle.d.ts",
    "bundle.js",
    "types.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf utils/shared && cp -r ../shared utils/shared && npx tsx ../scripts/minify-html.ts && vite build && vite build --mode bundle && npx tsc --declaration --emitDeclarationOnly && npx tsx ../scripts/tsc-alias.ts --alias '@nectary/shared=./utils/shared'",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@babel/runtime": "^7.22.15",
    "dts-bundle-generator": "^9.5.1",
    "lottie-web": "^5.12.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.22.15",
    "@babel/core": "^7.22.20",
    "@babel/plugin-transform-runtime": "^7.22.15",
    "@babel/preset-env": "^7.22.20",
    "@babel/preset-typescript": "^7.22.15",
    "@types/node": "22.12.0",
    "@types/react": "^18.2.21",
    "babel-plugin-html-inline-minifier": "workspace:*",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "glob": "^11.0.1",
    "typescript": "^5.2.2",
    "vite": "^7.0.6"
  },
  "peerDependencies": {
    "@nectary/theme-base": "^1.0.0"
  }
}
