{
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "pretty": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "jsx": "react-jsx",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "paths": {
      "~/*": [
        "./src/*"
      ],
      "components/bootstrap": [
        "./versions"
      ],
    },
  },
}
